@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --obsidian-bg: #06070f;
    --obsidian-surface: #0d1120;
    --obsidian-border: #1e2340;
    --obsidian-cyan: #00f0ff;
    --obsidian-purple: #7c3aed;
    --obsidian-text: #e2e6f5;
    --obsidian-text-muted: #4b5280;
  }

  body {
    font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background-color: var(--obsidian-bg);
    color: var(--obsidian-text);
    overflow-x: clip;
    -webkit-font-smoothing: antialiased;
  }

  code, pre {
    font-family: 'DM Mono', 'Courier New', monospace;
  }

  /* Modern Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--obsidian-bg); }
  ::-webkit-scrollbar-thumb { 
    background: var(--obsidian-border); 
    border-radius: 10px;
    border: 2px solid var(--obsidian-bg);
  }
  ::-webkit-scrollbar-thumb:hover { background: var(--obsidian-cyan); }
}

@layer components {
  .glass-panel {
    @apply bg-opacity-20 backdrop-blur-lg border border-white/10 rounded-2xl;
  }
  
  .neon-glow {
    box-shadow: 0 0 20px rgba(0, 240, 255, 0.15);
  }

  .text-gradient {
    @apply bg-clip-text text-transparent bg-gradient-to-r from-[#00f0ff] to-[#7c3aed];
  }
}
