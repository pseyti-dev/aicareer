---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SkillChecklist from '../../components/SkillChecklist.jsx';
import { careers, author } from '../../data/careers.js';

export function getStaticPaths() {
  return careers.map((career) => ({
    params: { slug: career.slug },
    props: { career },
  }));
}

const { career } = Astro.props;

const relatedCareers = careers.filter((c) => c.slug !== career.slug).slice(0, 3);

const replaceBottomLine =
  career.baseRiskScore > 70
    ? `At ${career.baseRiskScore}% risk, most routine ${career.title} tasks will be automated within 3–5 years. The role will not disappear overnight, but headcount will contract significantly — especially at the entry level, where the Stanford AI Index 2026 confirms the steepest job losses are already occurring. Human ${career.title}s will remain employed in advisory, exception-handling, and client-facing capacities that require trust and judgment.`
    : career.baseRiskScore > 40
      ? `At ${career.baseRiskScore}% risk, AI will automate a significant portion of this role's task load, but human ${career.title}s will remain essential for complex, relationship-dependent, and judgment-heavy work. The Stanford AI Index 2026 shows productivity gains in this category — meaning fewer people will do more work, not that the role disappears.`
      : `At ${career.baseRiskScore}% risk, this role is among the more AI-resilient in today's market. AI tools will augment rather than replace ${career.title}s in most scenarios. However, the Stanford AI Index 2026 cautions that entry-level positions in even "low risk" careers are vulnerable — junior developer employment fell ~20% in 2025–2026 despite software development being rated low-risk overall.`;

const replaceIcon = career.baseRiskScore > 70 ? '⚠' : career.baseRiskScore > 40 ? '⚡' : '✓';

const replaceBoxColor =
  career.baseRiskScore > 70
    ? 'border-rose-500/30 bg-rose-500/5'
    : career.baseRiskScore > 40
      ? 'border-amber-500/30 bg-amber-500/5'
      : 'border-emerald-500/30 bg-emerald-500/5';

const getBarColor = (score) => {
  if (score <= 40) return '#10b981';
  if (score <= 70) return '#f59e0b';
  return '#f43f5e';
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${career.title} AI Risk Score: ${career.baseRiskScore}% — How to Future-Proof Your Career`,
  description: career.aioSummary,
  url: `https://aicareer.me/risk/${career.slug}/`,
  author: { '@type': 'Person', name: author.name },
  publisher: { '@type': 'Organization', name: 'AI Career Risk', url: 'https://aicareer.me' },
  datePublished: '2026-01-01',
  dateModified: new Date().toISOString().slice(0, 10),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `What is the AI risk score for a ${career.title}?`,
      acceptedAnswer: { '@type': 'Answer', text: career.aioSummary },
    },
    {
      '@type': 'Question',
      name: `What tasks does AI already perform for a ${career.title}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `AI currently automates the following tasks in the ${career.title} role: ${career.automatedTasks.join('; ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `How to prepare for AI impact as a ${career.title}?`,
      acceptedAnswer: { '@type': 'Answer', text: career.howToFutureProof },
    },
    {
      '@type': 'Question',
      name: `What skills reduce AI risk for a ${career.title}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `The most effective skills to reduce AI risk for a ${career.title} include: ${career.skills.map((s) => s.name).join(', ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `Will AI completely replace ${career.title}s?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${career.aioSummary} Complete replacement is most likely for entry-level and routine-task positions within the role. Professionals who develop AI-adjacent skills and pivot toward judgment-heavy, relationship-driven work can reduce their personal displacement risk well below the ${career.baseRiskScore}% baseline. The Stanford AI Index 2026 confirms that entry-level workers in AI-exposed roles see the steepest employment declines, while senior professionals in the same fields hold steady or grow.`,
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://aicareer.me/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: `${career.title} AI Risk Assessment`,
      item: `https://aicareer.me/risk/${career.slug}/`,
    },
  ],
};
---

<BaseLayout
  title={`${career.title} AI Risk Score: ${career.baseRiskScore}% | aicareer.me`}
  description={`${career.title} AI risk is ${career.baseRiskScore}% (${career.riskLabel}). See which tasks AI already automates, the key skills to cut your risk, and a free upskilling roadmap.`}
  canonical={`https://aicareer.me/risk/${career.slug}/`}
  ogType="article"
  schema={[articleSchema, faqSchema, breadcrumbSchema]}
>
  <Nav />

  <div class="min-h-screen bg-[#06070f]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-[#4b5280]">
          <li><a href="/" class="hover:text-[#06B6D4] transition-colors">Home</a></li>
          <li><span class="mx-2 text-[#1e2340]">/</span></li>
          <li>
            <span class="text-[#e2e6f5] font-medium" aria-current="page"
              >{career.title} Risk Assessment</span
            >
          </li>
        </ol>
      </nav>

      <a
        href="/"
        class="inline-flex mb-8 px-4 py-2 rounded-lg border border-[#1e2340] text-[#e2e6f5] hover:border-[#06B6D4] transition-all items-center gap-2 text-sm"
      >
        ← All Careers
      </a>

      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#e2e6f5] mb-4">
          {career.title}
        </h1>
        <p class="text-lg text-[#4b5280]">AI Displacement Risk Assessment & Upskilling Roadmap</p>
      </div>

      <!-- AIO Summary — static, citable, in the HTML -->
      <div
        class="border-l-4 border-[#06B6D4] rounded-xl p-6 mb-8"
        style="background:rgba(6,182,212,0.06)"
      >
        <p class="text-sm text-[#e2e6f5] leading-relaxed font-medium">{career.aioSummary}</p>
      </div>

      <!-- Interactive Risk Gauge + Skill Checklist (React island) -->
      <SkillChecklist
        client:load
        skills={career.skills}
        slug={career.slug}
        baseRiskScore={career.baseRiskScore}
      />

      <!-- What AI Already Does — static HTML -->
      <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-8 mb-8">
        <h2 class="text-xl font-bold text-[#e2e6f5] mb-4">What AI Already Does in This Role</h2>
        <p class="text-sm text-[#4b5280] mb-4">
          These are the specific tasks that AI tools currently perform for {career.title}s, reducing
          demand for human execution:
        </p>
        <ul class="space-y-3">
          {
            career.automatedTasks.map((task) => (
              <li class="flex items-start gap-3 text-sm text-[#4b5280]">
                <span class="text-[#f43f5e] mt-0.5 flex-shrink-0">⚠</span>
                <span>{task}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Article — rich static content for SEO -->
      <article class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#e2e6f5] mb-4">
          Why {career.title}s Are at Risk from AI Automation
        </h2>
        <p class="text-[#4b5280] mb-6 leading-relaxed">
          The role of a {career.title} is undergoing a significant transformation driven by rapid advances
          in artificial intelligence. With a baseline AI displacement risk score of <strong
            class="text-[#e2e6f5]">{career.baseRiskScore}%</strong
          >, professionals in this field face some of the most acute automation pressure in the
          current labor market. {career.whyAtRisk}
        </p>
        <p class="text-[#4b5280] mb-8 leading-relaxed">
          As companies adopt machine learning and natural language processing at scale, demand for
          traditional, routine-based execution continues to decline. The professionals who will
          thrive are those who pivot toward work requiring complex judgment, contextual expertise,
          and trust-based human relationships that AI cannot replicate.
        </p>
        <h2 class="text-2xl font-bold text-[#e2e6f5] mb-4">
          How to Future-Proof Your Career as a {career.title}
        </h2>
        <p class="text-[#4b5280] leading-relaxed">
          {career.howToFutureProof} The key is to reposition yourself as an AI-augmented professional
          — someone who leverages AI tools to deliver higher output while focusing human energy on the
          strategic, creative, and relationship-driven dimensions of the role.
        </p>
      </article>

      <!-- Will AI Replace? — AIO-targeted section -->
      <section
        class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-8 mb-8"
        aria-labelledby={`replace-heading-${career.slug}`}
      >
        <h2 id={`replace-heading-${career.slug}`} class="text-2xl font-bold text-[#e2e6f5] mb-4">
          <span aria-hidden="true">{replaceIcon} </span>Will AI Replace {career.title}s?
        </h2>
        <p class="text-[#4b5280] leading-relaxed mb-4">{career.aioSummary}</p>
        <div class={`rounded-lg p-4 mb-4 border ${replaceBoxColor}`}>
          <p class="text-sm leading-relaxed text-[#e2e6f5]">
            <strong>Bottom line:</strong>
            {' '}{replaceBottomLine}
          </p>
        </div>
        <p class="text-xs text-[#4b5280]">
          Source: <a href="/study/ai-job-impact-2026/" class="text-[#06B6D4] hover:underline"
            >Stanford AI Index 2026 analysis</a
          > · <a href="/about/" class="text-[#06B6D4] hover:underline">Risk score methodology</a>
        </p>
      </section>

      <!-- FAQ — accordion (CSS-only, zero JS) -->
      <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-8 mb-8">
        <h2 class="text-2xl font-bold text-[#e2e6f5] mb-6">Frequently Asked Questions</h2>
        <div class="space-y-1">
          {
            faqSchema.mainEntity.map((faq) => (
              <details class="group border-b border-[#1e2340] last:border-0">
                <summary class="flex items-center justify-between gap-4 py-4 cursor-pointer list-none text-base font-bold text-[#e2e6f5] hover:text-[#06B6D4] transition-colors">
                  {faq.name}
                  <span class="flex-shrink-0 text-[#4b5280] group-open:rotate-45 transition-transform duration-200 text-xl leading-none">
                    +
                  </span>
                </summary>
                <p class="text-sm text-[#4b5280] leading-relaxed pb-4">{faq.acceptedAnswer.text}</p>
              </details>
            ))
          }
        </div>
      </div>

      <!-- Related Careers -->
      <div class="mb-8">
        <h2 class="text-xl font-bold text-[#e2e6f5] mb-4">Other At-Risk Career Assessments</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          {
            relatedCareers.map((rc) => (
              <a
                href={`/risk/${rc.slug}/`}
                class="bg-[#0d1120] border border-[#1e2340] rounded-lg p-4 hover:border-[#06B6D4] transition-all"
              >
                <h3 class="font-bold text-[#e2e6f5] mb-1 text-sm">{rc.title}</h3>
                <span class="text-sm text-[#f43f5e]">{rc.baseRiskScore}% Risk</span>
              </a>
            ))
          }
        </div>

        <div
          class="border border-[#06B6D4] rounded-xl p-8 text-center"
          style="background: linear-gradient(135deg, #0d1120, #1e2340)"
        >
          <h2 class="text-xl font-bold text-[#e2e6f5] mb-3">Want to be AI-Ready in Any Job?</h2>
          <p class="text-[#4b5280] mb-6 text-sm">
            Discover the universal AI skills that protect any career, regardless of industry.
          </p>
          <a
            href="/special/ai-ready/"
            class="inline-block px-8 py-4 rounded-lg font-bold text-white"
            style="background: linear-gradient(135deg, #06B6D4 0%, #7C3AED 100%); box-shadow: 0 4px 12px rgba(6,182,212,0.3)"
          >
            Learn Universal AI Skills →
          </a>
        </div>
      </div>

      <div class="text-center">
        <a
          href="/"
          class="inline-block px-8 py-4 rounded-lg border border-[#1e2340] font-bold text-[#e2e6f5] hover:border-[#06B6D4] hover:text-[#06B6D4] transition-all"
        >
          ← Explore All Careers
        </a>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>
