---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CareerSelector from '../components/CareerSelector.jsx';
import { careers, specialOptions, methodology, marketStats, riskRankings, author } from '../data/careers.js';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AI Career Risk Calculator",
  "applicationCategory": "BusinessApplication",
  "url": "https://aicareer.me",
  "description": "Free tool to assess AI job displacement risk scores for specific careers and generate personalized upskilling roadmaps.",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Person", "name": author.name }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Which jobs are most at risk of AI automation?", "acceptedAnswer": { "@type": "Answer", "text": "The jobs most at risk of AI automation in 2026 are: Data Entry Clerk (95%), Bookkeeper (90%), Customer Service Representative (82%), Paralegal (78%), Medical Coder (72%), Loan Officer (65%), and Sales Representative (58%). These roles have the highest concentration of tasks that AI can already perform reliably." } },
    { "@type": "Question", "name": "How can I future-proof my career against AI?", "acceptedAnswer": { "@type": "Answer", "text": "To future-proof your career against AI, focus on three areas: develop AI literacy and learn to use AI tools relevant to your field; shift toward human-judgment tasks like strategic thinking and client relationships; and acquire cross-functional skills in data analysis, project management, and communication." } },
    { "@type": "Question", "name": "How is the AI risk score calculated?", "acceptedAnswer": { "@type": "Answer", "text": "Our AI risk score is a composite index built on three dimensions: Task Routinization (40%), AI Tool Penetration (35%), and Human Judgment Dependency (25%). Based on research by Oxford University, McKinsey Global Institute, and the World Economic Forum." } },
    { "@type": "Question", "name": "Can I reduce my AI displacement risk?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our interactive tool lets you check off skills as you acquire them, and your personal risk score decreases accordingly. Professionals who proactively learn AI-adjacent skills typically reduce their displacement risk by 30-50 percentage points." } }
  ]
};

const getBarColor = (score) => {
  if (score <= 40) return '#10b981';
  if (score <= 70) return '#f59e0b';
  return '#f43f5e';
};
---

<BaseLayout
  title="Free AI Career Risk Calculator: Is Your Job Safe from AI? | aicareer.me"
  description="Check your AI job displacement risk score instantly. Free calculator for 7 high-risk careers. Get a personalized upskilling roadmap to future-proof your career."
  canonical="https://aicareer.me/"
  schema={[orgSchema, faqSchema]}
>
  <Nav />

  <main>

    <!-- ── Hero ── -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-20 text-center">
      <nav aria-label="Breadcrumb" class="mb-6 flex justify-center">
        <ol class="flex items-center space-x-2 text-sm text-[#4b5280]">
          <li><span class="text-[#e2e6f5] font-medium" aria-current="page">Home</span></li>
        </ol>
      </nav>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-[#e2e6f5] mb-6 leading-tight">
        Is Your Job
        <span class="bg-clip-text text-transparent" style="background-image: linear-gradient(135deg, #06B6D4 0%, #7C3AED 100%)">
          Safe from AI?
        </span>
      </h1>
      <p class="text-lg sm:text-xl text-[#4b5280] mb-3 max-w-2xl mx-auto">
        Free AI displacement risk calculator for 7 high-risk careers.
      </p>
      <p class="text-base text-[#4b5280] mb-10 max-w-2xl mx-auto">
        Get your personal risk score and a step-by-step upskilling roadmap — based on research from Oxford, McKinsey, and the World Economic Forum.
      </p>

      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <span class="px-4 py-2 rounded-full bg-[#0d1120] border border-[#1e2340] text-sm text-[#e2e6f5]">🎯 7 High-Risk Careers</span>
        <span class="px-4 py-2 rounded-full bg-[#0d1120] border border-[#1e2340] text-sm text-[#e2e6f5]">📊 Instant Risk Score</span>
        <span class="px-4 py-2 rounded-full bg-[#0d1120] border border-[#1e2340] text-sm text-[#e2e6f5]">🚀 Free Upskilling Path</span>
        <span class="px-4 py-2 rounded-full bg-[#0d1120] border border-[#1e2340] text-sm text-[#e2e6f5]">🔒 No Sign-Up Required</span>
      </div>

      <!-- React island — only the dropdown is interactive -->
      <CareerSelector client:load careers={careers} specialOptions={specialOptions} />
    </section>

    <!-- ── Market Stats ── -->
    <section class="border-t border-[#1e2340] bg-[#0a0c18] py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-[#e2e6f5] mb-3 text-center">
          The Impact of AI on the Job Market in 2026
        </h2>
        <p class="text-[#4b5280] text-center mb-10 max-w-2xl mx-auto">
          The AI-driven transformation of the labor market is accelerating faster than most workers realize.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {marketStats.map(stat => (
            <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-5 text-center">
              <div class="text-3xl font-bold text-[#06B6D4] mb-1">{stat.figure}</div>
              <div class="text-sm text-[#e2e6f5] mb-2">{stat.label}</div>
              <div class="text-xs text-[#4b5280]">— {stat.source}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Career Cards ── AIO static content lives here -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-[#e2e6f5] mb-3 text-center">
        Top Jobs Most at Risk of AI Automation in 2026
      </h2>
      <p class="text-[#4b5280] text-center mb-10 max-w-2xl mx-auto">
        Each career has a dedicated risk assessment with specific skills to reduce your personal risk score.
      </p>

      <!-- AIO crawlable summary — always in HTML, visible to all crawlers -->
      <div class="sr-only">
        {riskRankings.map(r => (
          <p>#{r.rank}: The AI replacement risk for a {r.title} is {r.risk}% due to {r.reason}.</p>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {careers.map(career => {
          const color = getBarColor(career.baseRiskScore);
          return (
            <a href={`/risk/${career.slug}/`}
              aria-label={`${career.title} AI risk assessment — ${career.baseRiskScore}% risk`}
              class="block bg-[#0d1120] border border-[#1e2340] rounded-xl p-6 text-left transition-all duration-200 hover:border-[#06B6D4] hover:shadow-lg group">
              <h3 class="text-lg font-bold text-[#e2e6f5] mb-2 group-hover:text-[#06B6D4] transition-colors">{career.title}</h3>
              <p class="text-xs text-[#4b5280] mb-3 line-clamp-2">{career.aioSummary}</p>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl font-bold text-[#e2e6f5]">{career.baseRiskScore}%</span>
                <span class="px-2 py-1 rounded text-xs font-bold uppercase"
                  style={`background-color:${color}20;color:${color}`}>{career.riskLabel}</span>
              </div>
              <div class="w-full h-2 bg-[#1e2340] rounded-full overflow-hidden">
                <div class="h-full rounded-full" style={`width:${career.baseRiskScore}%;background-color:${color}`}></div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- ── Future-Proof Framework ── -->
    <section class="border-t border-[#1e2340] bg-[#0a0c18] py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-[#e2e6f5] mb-3 text-center">
          How to Future-Proof Your Career Against AI
        </h2>
        <p class="text-[#4b5280] text-center mb-10 max-w-2xl mx-auto">
          The professionals who thrive in the AI era aren't those who avoid AI — they're the ones who learn to work alongside it.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { step: "01", title: "Know Your Risk", desc: "Start by honestly assessing how much of your current work is routine and predictable. Our calculator gives you a baseline score based on your profession.", color: "#f43f5e" },
            { step: "02", title: "Learn AI Tools", desc: "Master the AI tools entering your industry. Becoming the person who runs the AI — rather than being replaced by it — requires deliberate skill-building.", color: "#f59e0b" },
            { step: "03", title: "Shift to Human Work", desc: "Move your career toward tasks requiring judgment, creativity, trust, and emotional intelligence. These are the domains where AI still falls short.", color: "#10b981" }
          ].map(item => (
            <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-6">
              <div class="text-4xl font-bold mb-3" style={`color:${item.color}`}>{item.step}</div>
              <h3 class="text-lg font-bold text-[#e2e6f5] mb-2">{item.title}</h3>
              <p class="text-sm text-[#4b5280] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Methodology ── -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16" id="methodology">
      <h2 class="text-2xl sm:text-3xl font-bold text-[#e2e6f5] mb-3 text-center">
        {methodology.title}
      </h2>
      <p class="text-[#4b5280] text-center mb-10 max-w-2xl mx-auto">{methodology.description}</p>
      <div class="space-y-4 mb-6">
        {methodology.dimensions.map(dim => (
          <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-6 flex gap-4">
            <div class="flex-shrink-0">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-[#06B6D4] bg-opacity-20 text-[#06B6D4] border border-[#06B6D4]">
                {dim.weight}
              </span>
            </div>
            <div>
              <h3 class="font-bold text-[#e2e6f5] mb-1">{dim.name}</h3>
              <p class="text-sm text-[#4b5280] leading-relaxed">{dim.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="bg-[#0d1120] border border-[#1e2340] border-l-4 border-l-[#06B6D4] rounded-xl p-5">
        <p class="text-sm text-[#4b5280] leading-relaxed">
          <span class="text-[#e2e6f5] font-medium">Note: </span>{methodology.note}
        </p>
      </div>
    </section>

    <!-- ── About / E-E-A-T ── -->
    <section class="border-t border-[#1e2340] bg-[#0a0c18] py-16" id="about">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-[#e2e6f5] mb-6">Who Built This</h2>
        <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-8">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white mx-auto mb-4"
            style="background: linear-gradient(135deg, #06B6D4, #7C3AED)">
            {author.name.charAt(0)}
          </div>
          <h3 class="text-xl font-bold text-[#e2e6f5] mb-1">{author.name}</h3>
          <p class="text-sm text-[#06B6D4] mb-4">{author.role}</p>
          <p class="text-[#4b5280] leading-relaxed mb-6">{author.bio}</p>
          <div class="flex flex-wrap justify-center gap-2 mb-6">
            {author.expertise.map(skill => (
              <span class="px-3 py-1 rounded-full text-xs font-medium bg-[#1e2340] text-[#e2e6f5]">{skill}</span>
            ))}
          </div>
          <p class="text-xs text-[#4b5280]">
            This tool covers career topics (YMYL). Scores are based on published labor economics research for informational purposes only.
          </p>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-[#e2e6f5] mb-10 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <div class="bg-[#0d1120] border border-[#1e2340] rounded-xl p-6">
            <h3 class="font-bold text-[#e2e6f5] mb-3">{item.name}</h3>
            <p class="text-sm text-[#4b5280] leading-relaxed">{item.acceptedAnswer.text}</p>
          </div>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
