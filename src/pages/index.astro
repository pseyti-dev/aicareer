---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CareerSelector from '../../components/CareerSelector.jsx';
import { careers, methodology, marketStats, author } from '../../data/careers.js';

// Schema and color logic (kept same for SEO continuity)
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AI Career Risk Calculator",
  "applicationCategory": "BusinessApplication",
  "url": "https://aicareer.me",
  "description": "Assess AI job displacement risk scores for careers.",
  "author": { "@type": "Person", "name": author.name }
};

const getBarColor = (score) => {
  if (score <= 40) return '#00f0ff'; // Neon Cyan
  if (score <= 70) return '#f59e0b';
  return '#f43f5e';
};
---

<BaseLayout
  title="Free AI Career Risk Calculator | aicareer.me"
  description="Check your AI job displacement risk score instantly. Personalized upskilling roadmaps."
  canonical="https://aicareer.me/"
  schema={[orgSchema]}
>
  <Nav />
  
  <main class="pt-24 pb-20">
    <!-- ── Hero: Obsidian Terminal ── -->
    <section class="max-w-4xl mx-auto px-6 py-16 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#00f0ff]/30 bg-[#00f0ff]/5 text-[10px] uppercase tracking-widest text-[#00f0ff] mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00f0ff] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00f0ff]"></span>
        </span>
        Obsidian Neural Model 4.2 Active
      </div>
      
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
        Is Your Career <br/>
        <span class="text-gradient">Future-Proof?</span>
      </h1>
      
      <p class="text-lg text-[#4b5280] mb-12 max-w-2xl mx-auto leading-relaxed">
        Our intelligence engine calculates real-time AI displacement risks using global market data and predictive neural modeling.
      </p>

      <!-- Calculator Terminal -->
      <div class="bg-[#0d1120] border border-[#1e2340] rounded-2xl p-2 max-w-xl mx-auto neon-glow">
        <div class="flex items-center gap-4 px-4 py-3">
          <div class="flex-grow">
            <CareerSelector client:load careers={careers} />
          </div>
        </div>
      </div>
    </section>

    <!-- ── Market Insights ── -->
    <section class="max-w-7xl mx-auto px-6 py-20 border-t border-[#1e2340]">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <h2 class="text-3xl font-bold mb-4 tracking-tight text-gradient">Real-time Intelligence</h2>
          <p class="text-[#4b5280] leading-relaxed">
            The AI-driven transformation of the labor market is accelerating faster than most workers realize.
          </p>
        </div>
        <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-3 gap-6">
          {marketStats.map(stat => (
            <div class="bg-[#0d1120]/50 border border-[#1e2340] rounded-2xl p-6 text-center">
              <div class="text-4xl font-bold text-[#00f0ff] mb-2">{stat.figure}</div>
              <div class="text-xs uppercase tracking-widest text-[#4b5280]">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Career Index ── -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-bold mb-12 text-center">Risk Analysis by Profession</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {careers.map(career => (
          <a href={`/risk/${career.slug}/`} class="group block bg-[#0d1120] border border-[#1e2340] rounded-2xl p-8 transition-all hover:border-[#00f0ff] hover:scale-[1.02]">
            <h3 class="text-xl font-bold mb-4 group-hover:text-[#00f0ff] transition-colors">{career.title}</h3>
            <div class="flex items-end justify-between mb-4">
              <span class="text-3xl font-bold">{career.baseRiskScore}%</span>
              <span class="text-[10px] uppercase tracking-widest text-[#4b5280]">Risk Metric</span>
            </div>
            <div class="w-full h-1 bg-[#1e2340] rounded-full overflow-hidden">
              <div class="h-full bg-[#00f0ff] shadow-[0_0_8px_#00f0ff]" style={`width: ${career.baseRiskScore}%`}></div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Methodology ── -->
    <section class="max-w-5xl mx-auto px-6 py-24 bg-[#0d1120] border-y border-[#1e2340]">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold mb-4">{methodology.title}</h2>
        <p class="text-[#4b5280]">{methodology.description}</p>
      </div>
      <div class="grid gap-6">
        {methodology.dimensions.map(dim => (
          <div class="flex items-start gap-6 p-6 rounded-2xl border border-[#1e2340] bg-[#06070f]">
            <div class="px-3 py-1 rounded bg-[#00f0ff]/10 text-[#00f0ff] text-xs font-bold">{dim.weight}</div>
            <div>
              <h4 class="font-bold mb-2">{dim.name}</h4>
              <p class="text-sm text-[#4b5280] leading-relaxed">{dim.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
